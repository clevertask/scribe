{
  "name": "@clevertask/scribe",
  "version": "0.0.14",
  "private": false,
  "description": "A Tiptap-based rich text editor with a Notion-style block interface for viewing and creating content. Perfect for diverse needs like notes, documents, AI chat, Markdown parsing, and comments.",
  "keywords": [
    "block-based",
    "editor",
    "javascript",
    "notion",
    "prosemirror",
    "react",
    "rich-text-editor",
    "tiptap",
    "typescript",
    "wysiwyg"
  ],
  "homepage": "https://github.com/clevertask/scribe#readme",
  "bugs": {
    "url": "https://github.com/clevertask/scribe/issues"
  },
  "license": "MIT",
  "author": "CleverTask",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/clevertask/scribe.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/main.js",
  "types": "dist/main.d.ts",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && npm run build:style && tsc -p tsconfig.types.json --noCheck",
    "build:style": "postcss ./lib/styles/main.css -o ./dist/main.css",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check"
  },
  "dependencies": {
    "@tiptap/core": "^2.27.2",
    "@tiptap/extension-emoji": "^2.27.2",
    "@tiptap/extension-focus": "^2.27.2",
    "@tiptap/extension-highlight": "^2.27.2",
    "@tiptap/extension-image": "^2.27.2",
    "@tiptap/extension-link": "^2.27.2",
    "@tiptap/extension-mathematics": "^3.21.0",
    "@tiptap/extension-placeholder": "^2.27.2",
    "@tiptap/extension-table": "^2.27.2",
    "@tiptap/extension-table-cell": "^2.27.2",
    "@tiptap/extension-table-header": "^2.27.2",
    "@tiptap/extension-table-row": "^2.27.2",
    "@tiptap/extension-task-item": "^2.27.2",
    "@tiptap/extension-task-list": "^2.27.2",
    "@tiptap/extension-typography": "^2.27.2",
    "@tiptap/pm": "^2.27.2",
    "@tiptap/react": "^2.27.2",
    "@tiptap/starter-kit": "^2.27.2",
    "@tiptap/suggestion": "^2.27.2",
    "clsx": "^2.1.1",
    "dompurify": "^3.3.3",
    "katex": "^0.16.44",
    "marked": "^15.0.12",
    "tippy.js": "^6.3.7",
    "turndown": "^7.2.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/typography": "^0.5.19",
    "@types/lodash": "^4.17.24",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/turndown": "^5.0.6",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "glob": "^13.0.6",
    "globals": "^17.4.0",
    "lodash": "^4.17.23",
    "oxfmt": "^0.37.0",
    "postcss": "^8.5.8",
    "postcss-cli": "^11.0.1",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.2",
    "vite": "^7.3.1",
    "vite-plugin-lib-inject-css": "^2.2.2"
  },
  "peerDependencies": {
    "react": ">=18.3.1 <20.0.0",
    "react-dom": ">=18.3.1 <20.0.0"
  },
  "prepublishOnly": "npm run build"
}
