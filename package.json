{
  "name": "@clevertask/scribe",
  "description": "A Tiptap-based rich text editor with a Notion-style block interface for viewing and creating content. Perfect for diverse needs like notes, documents, AI chat, Markdown parsing, and comments.",
  "author": "CleverTask",
  "private": false,
  "version": "0.0.13",
  "type": "module",
  "main": "dist/main.js",
  "types": "dist/main.d.ts",
  "files": [
    "dist"
  ],
  "keywords": [
    "react",
    "javascript",
    "editor",
    "typescript",
    "prosemirror",
    "wysiwyg",
    "rich-text-editor",
    "notion",
    "block-based",
    "tiptap"
  ],
  "license": "MIT",
  "homepage": "https://github.com/clevertask/scribe#readme",
  "bugs": {
    "url": "https://github.com/clevertask/scribe/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/clevertask/scribe.git"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && npm run build:style",
    "build:style": "postcss ./lib/styles/main.css -o ./dist/main.css",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "prettier:lint": "npx prettier . --check",
    "prettier:format": "npx prettier . --write"
  },
  "peerDependencies": {
    "react": ">=18.3.1 <20.0.0",
    "react-dom": ">=18.3.1 <20.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@tailwindcss/typography": "^0.5.19",
    "@types/lodash": "^4.17.23",
    "@types/node": "^24.10.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/turndown": "^5.0.6",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.24",
    "eslint": "^9.39.3",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.0",
    "glob": "^13.0.6",
    "globals": "^17.3.0",
    "lodash": "^4.17.23",
    "postcss": "^8.5.6",
    "postcss-cli": "^11.0.1",
    "prettier": "3.4.2",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.0",
    "unplugin-dts": "1.0.0-beta.6",
    "vite": "^7.3.1",
    "vite-plugin-lib-inject-css": "^2.2.2"
  },
  "prepublishOnly": "npm run build",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "@tiptap/core": "^2.27.2",
    "@tiptap/extension-emoji": "^2.27.2",
    "@tiptap/extension-focus": "^2.27.2",
    "@tiptap/extension-highlight": "^2.27.2",
    "@tiptap/extension-image": "^2.27.2",
    "@tiptap/extension-link": "^2.27.2",
    "@tiptap/extension-mathematics": "^3.20.0",
    "@tiptap/extension-placeholder": "^2.27.2",
    "@tiptap/extension-table": "^2.27.2",
    "@tiptap/extension-table-cell": "^2.27.2",
    "@tiptap/extension-table-header": "^2.27.2",
    "@tiptap/extension-table-row": "^2.27.2",
    "@tiptap/extension-task-item": "^2.27.2",
    "@tiptap/extension-task-list": "^2.27.2",
    "@tiptap/extension-typography": "^2.27.2",
    "@tiptap/pm": "^2.27.2",
    "@tiptap/react": "^2.27.2",
    "@tiptap/starter-kit": "^2.27.2",
    "@tiptap/suggestion": "^2.27.2",
    "clsx": "^2.1.1",
    "dompurify": "^3.3.1",
    "katex": "^0.16.28",
    "marked": "^15.0.12",
    "tippy.js": "^6.3.7",
    "turndown": "^7.2.2"
  }
}
